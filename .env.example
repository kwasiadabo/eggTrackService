PORT=5000

# MSSQL Connection
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=EggDistributionDB
DB_USER=sa
DB_PASSWORD=YourStrong@Password123
DB_ENCRYPT=false
DB_TRUST_CERT=true

# Prisma (used by `prisma db pull` / `prisma generate` via prisma.config.ts; mirrors DB_* above)
DATABASE_URL=sqlserver://localhost:1433;database=EggDistributionDB;user=sa;password=YourStrong@Password123;encrypt=false;trustServerCertificate=true

# JWT — change BOTH secrets before going to production!
JWT_SECRET=eggtrack_jwt_super_secret_change_me_in_production
JWT_REFRESH_SECRET=eggtrack_refresh_super_secret_change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Resend) — SMTP to Gmail isn't reliable from PaaS hosts (Render etc.),
# so transactional email goes through Resend's HTTP API instead.
# Get an API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# Sender address. The shared 'onboarding@resend.dev' sender can only deliver
# to your own Resend account email — verify a domain at resend.com/domains
# and set this to an address on that domain to email other recipients.
EMAIL_FROM="EggTrack Reports <onboarding@resend.dev>"
